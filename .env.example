# RetailOS Environment Configuration
# Copy to .env and fill in your values

# ── Core ──
GEMINI_API_KEY=your-gemini-api-key-here
PORT=8000

# ── Database ──
# SQLite (default): sqlite+aiosqlite:///data/retailos.db
# PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/retailos
DATABASE_URL=sqlite+aiosqlite:///data/retailos.db

# ── Redis (optional, falls back to in-memory) ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_EXPIRE_SECONDS=86400

# ── Email Notifications (optional) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@retailos.app
SMTP_USE_TLS=true

# ── SMS (MSG91 or Twilio) ──
SMS_PROVIDER=msg91
MSG91_API_KEY=
MSG91_SENDER_ID=RETLOS
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── WhatsApp Business API (optional) ──
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# ── Payments (Razorpay) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Error Tracking (Sentry) ──
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Encryption ──
ENCRYPTION_KEY=

# ── Tally ERP ──
TALLY_URL=
TALLY_COMPANY=RetailOS Store

# ── Web Push (VAPID) ──
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@retailos.app

# ── Logging ──
LOG_LEVEL=INFO
LOG_FORMAT=json
